{{!< default}}
<header class="archive-header">
  <div class="container">
    <p class="eyebrow">Author</p>
    {{#author}}
    <h1>{{name}}</h1>
    {{#if bio}}<p class="archive-header__desc">{{bio}}</p>{{/if}}
    {{/author}}
  </div>
</header>
<div class="container">
  <div class="post-feed">{{#foreach posts}}{{> post-card}}{{/foreach}}</div>
  {{pagination}}
</div>
