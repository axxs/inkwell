{{!< default}}
{{#post}}
<article class="post">
  <header class="post__header container">
    {{#if primary_tag}}<a class="eyebrow" href="{{primary_tag.url}}">{{primary_tag.name}}</a>{{/if}}
    <h1 class="post__title">{{title}}</h1>
    <p class="post__meta">{{primary_author.name}} · {{date format="D MMMM YYYY"}} · {{reading_time}}</p>
  </header>
  {{#if feature_image}}
    <figure class="post__feature">
      <img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" />
    </figure>
  {{/if}}
  <div class="post-content gh-content container">{{content}}</div>
  <footer class="post__footer container">
    {{#if tags}}<div class="post__tags">{{tags prefix="Tagged: "}}</div>{{/if}}
  </footer>
</article>
{{> subscribe-cta}}
{{#if comments}}<div class="container post__comments">{{comments}}</div>{{/if}}
{{/post}}
