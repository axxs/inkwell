{{!< default}}
{{#post}}
<article class="page">
  {{#if @page.show_title_and_feature_image}}
  <header class="post__header container">
    <h1 class="post__title">{{title}}</h1>
  </header>
  {{#if feature_image}}
    <figure class="post__feature"><img src="{{img_url feature_image size="xl"}}" alt="{{title}}" /></figure>
  {{/if}}
  {{/if}}
  <div class="post-content gh-content container">{{content}}</div>
</article>
{{/post}}
